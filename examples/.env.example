# ICE configuration for examples/browser-server.ts
#
# Copy this file to examples/.env and edit. The server loads it automatically
# (Node 20.12+ built-in env-file support — no dependency). examples/.env is
# gitignored.
#
# The two peers use DIFFERENT servers and still connect: the Node peer relays
# through TURN, the browser uses STUN only, and ICE pairs Node's relay candidate
# with the browser's server-reflexive (srflx) candidate.

# --- Node side: TURN (relay) ---
# Plain TURN over UDP:        turn:host:3478
# TURN-over-TLS/DTLS:         turns:host:5349  /  turns:host:5349?transport=tcp
TURN_URL=turn:127.0.0.1:3478

# Long-term credentials (must match the TURN server's --user / --lt-cred-mech).
TURN_USER=testuser
TURN_PASS=testpass

# ICE transport policy for the Node peer: "all" (host/srflx/relay) or "relay"
# (force everything through TURN). The browser always uses "all" so it can offer
# its srflx candidate.
ICE_TRANSPORT_POLICY=all

# --- Browser side: STUN only ---
STUN_URL=stun:stun.cloudflare.com:3478

# HTTP port for the demo page / signaling.
PORT=3000
